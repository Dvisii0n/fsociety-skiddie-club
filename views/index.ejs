<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="stylesheet" href="styles.css">
	<title>Fsociety Skiddie Club</title>
</head>

<body>
	<% if (currentUser) {%>
		<h1><%= currentUser.username%></h1>
		<h2><%= currentUser.member_status  %></h2>
		<a href="/logout">Log out</a>
	<%}%>

	<% if (currentUser.member_status === 'guest') {%>
		<button command="show-modal" commandfor="joinForm">Join the club</button>
		<dialog id="joinForm">
			<form action="/join" method="POST">
				<label for="passcode">Enter the secret passcode</label>
				<input type="text" name="passcode" id="passcode" placeholder="hint: show name">
				<button type="submit">Join</button>
				<button type="button" commandfor="joinForm" command="close">Close</button>
			</form>
		</dialog>

	<%} %>

	<% if (currentUser.member_status !== 'guest') {%>
		<button>Post message</button>
		
		<%} %>

	<% userMessages.forEach((userMsg) => {%>
		<%- include("message", {msg: userMsg, memberStatus: currentUser.member_status}) %>
	<%}) %>

</body>

</html>